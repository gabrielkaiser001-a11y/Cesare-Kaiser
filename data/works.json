  "johannesprolog": [
    {
      "title": "Am Anfang war das Wort",
      "img": "Front/Johannesprolog/1.jpg",
      "desc": "Johannesevangelium 1,1: Tonträger erinnern an die Kraft des Wortes und daran, wie leicht aus dem Wort viele Wörter werden können.",
      "size": "100 x100 cm",
      "extra": null
    },
    {
      "title": "und Gott war das Wort",
      "img": "Front/Johannesprolog/2.jpg",
      "desc": "Johannesevangelium 1,1: Auf der zweiten Tafel bilden Tonträger das Wort „Gott“ und stellen die Fage, was wir unter Gott verstehen",
      "size": "100 x100 cm",
      "extra": null
    },
    {
      "title": "Und das Licht leuchtet in  der Finsternis, und die Finsternis hat es nicht ergriffen",
      "img": "Front/Johannesprolog/3.jpg",
      "desc": "Johannesevangelium 1,5: Zahlreiche Hände strecken sich einem Lichtstrahl entgegen der sich als Arm des Gekreuzigten erweist - das klassische Motiv der Hand Gottes, die sich dem Menschen entgegenstreckt!",
      "size": "100 x100 cm",
      "extra": null
    },
    {
      "title": "Er war in der Welt, und die Welt ist durch ihn gemacht, aber die Welt erkannte ihn nicht“ Er war in der Welt",
      "img": "Front/Johannesprolog/4.jpg",
      "desc": "Johannesevangelium 1,10: Hier wird die Darstellung des Menschen von da Vinci aufgegriffen. Ein Sandrund lässt an die Welt denken, in die der (gekreuzigte?) Mensch eingeschrieben ist. Eine runde Sache als Mittelpunkt der Serie!",
      "size": "100 x100 cm",
      "extra": null
    },
    {
      "title": "Er kam in sein Eigentum, aber die Seinen nahmen ihn nicht auf",
      "img": "Front/Johannesprolog/5.jpg",
      "desc": "Johannesevangelium 1,11: Auf dieser Tafel hängt der Gekreuzigte an einem Gitter, das ihn von unserer Welt trennt. Die Welt nimmt wieder das Motiv des Tonträgers auf.",
      "size": "100 x100 cm",
      "extra": null
    },
    {
      "title": "Und das Wort ward Fleisch",
      "img": "Front/Johannesprolog/6.jpg",
      "desc": "Johannesevangelium 1,14: Hier wird das fleischgewordene Wort wieder zwischen Schriftworten eingeklemmt und zum toten Buchstaben.",
      "size": "100 x100 cm",
      "extra": null
    },
    {
      "title": "und wohnte unter uns und wir sahen seine Herrlichkeit",
      "img": "Front/Johannesprolog/7.jpg",
      "desc": "Johannesevangelium 1,14: Auf der letzten Tafel weist das Stigma alls einzig farbiger Punkt der Serie den Umarmenden als Gekreuzigten aus, dessen Nähe nicht auf Anhieb erkannt wird.",
      "size": "100 x100 cm",
      "extra": null
    }
  ],
